{
  "name": "modus-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter @modus/web --filter @modus/student --filter @modus/teacher dev",
    "dev:web": "pnpm --filter @modus/web dev",
    "dev:student": "pnpm --filter @modus/student dev",
    "dev:teacher": "pnpm --filter @modus/teacher dev",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "packageManager": "pnpm@10.15.1"
}
